# ==================== API 配置 ====================
# DeepSeek API Key (必需)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# AMiner API Token (用于中文文献搜索)
# 获取地址: https://www.aminer.cn/open/board?tab=control
# 注意: Token 有效期为 100 天，过期后需要重新获取
AMINER_API_TOKEN=your_aminer_api_token_here
AMINER_TOKEN_EXPIRES_AT=YYYY-MM-DD

# ==================== 数据库配置 ====================
# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=security
DB_NAME=paper

# SQLite 数据库文件路径（备用）
DATABASE_URL=sqlite:///./papers.db

# ==================== 搜索配置 ====================
# 综述生成验证失败时的最大重试次数
MAX_RETRIES=1

# 触发补充搜索的最小文献数量
MIN_PAPERS_THRESHOLD=20

# 候选池大小为目标数量的倍数
CANDIDATE_POOL_MULTIPLIER=2

# 每次API调用返回的论文数量上限
PAPERS_PER_PAGE=100

# ==================== API 速率限制 ====================
# AMiner API 每秒调用次数限制
AMINER_RATE_LIMIT=1.0

# OpenAlex API 每秒调用次数限制
OPENALEX_RATE_LIMIT=5.0

# Semantic Scholar API 每秒调用次数限制
SEMANTIC_SCHOLAR_RATE_LIMIT=0.1

# ==================== 数据源开关配置 ====================
# 通过设置 true/false 来启用/禁用各个数据源
# true=启用, false=禁用

# OpenAlex - 英文文献（主要数据源，免费）
OPENALEX_ENABLED=true

# Crossref - 期刊/会议论文（引用数据准确，免费）
CROSSREF_ENABLED=true

# DataCite - 研究数据集（免费 API）
DATACITE_ENABLED=true

# AMiner - 中文文献（需要 AMINER_API_TOKEN）
AMINER_ENABLED=true

# Semantic Scholar - AI增强搜索（免费但限流严格）
SEMANTIC_SCHOLAR_ENABLED=false

# 中文 DOI - 中文文献（需要单独的 API 密钥）
CHINESE_DOI_ENABLED=false

# ==================== 质量评分权重 ====================
# 被引量在质量评分中的权重 (0.0-1.0)
CITATION_WEIGHT=0.4

# 新近度在质量评分中的权重 (0.0-1.0)
RECENCY_WEIGHT=0.3

# 相关性在质量评分中的权重 (0.0-1.0)
RELEVANCE_WEIGHT=0.3

# ==================== 用户可配置参数（前端显示）====================
# 以下参数将在前端页面显示给用户配置，不是环境变量
# - target_count: 目标文献数量 (默认: 50, 范围: 10-100)
# - recent_years_ratio: 近5年文献占比 (默认: 0.5, 范围: 0.1-1.0)
# - english_ratio: 英文文献占比 (默认: 0.3, 范围: 0.1-1.0)
# - search_years: 搜索年份范围 (默认: 10, 范围: 5-30)
# - max_search_queries: 最多搜索查询数 (默认: 8, 范围: 1-20)
